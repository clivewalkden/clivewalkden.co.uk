---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Up from '../components/Up.astro';
import PortfolioSegment from '../components/PortfolioSegment.astro';
import GitHubStats from '../components/GitHubStats.astro';

interface Props {
  item: CollectionEntry<'portfolio'>;
}

const { item } = Astro.props;
const { data } = item;

const startStr = data.launched.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
const endStr = data.finished
  ? data.finished.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })
  : 'present';
---
<BaseLayout meta_title={data.meta_title} meta_description={data.meta_description}>
  <Header slot="header" currentPath={Astro.url.pathname} />
  <div slot="dropdown"></div>

  <div data-pagefind-body>
    <div class="mx-auto sm:max-w-xl md:max-w-full lg:max-w-screen-xl px-4 md:px-24 lg:px-8">
      <div class="flex items-center">
        <div class="flex-1">
          <h1 class="mb-5 font-sans text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl sm:leading-none">{data.title}</h1>
        </div>
        <div class="flex-1 mt-8 bg-cover bg-no-repeat h-64 bg-top-9 border-l border-r border-t border-white rounded-t-lg shadow-md"
             style={`background-image: url('/assets/images/portfolio/${data.image_small ?? data.image_main}')`}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1376 80"
               class="text-white border-b fill-current border-soft rounded-tl-md rounded-tr-md">
            <g data-name="TOP BAR">
              <rect class="text-white fill-current" width="1376" height="80"></rect>
            </g>
            <g data-name="BUTTONS">
              <circle class="text-red-400 fill-current" cx="37" cy="40" r="11"></circle>
              <circle class="text-yellow-400 fill-current" cx="71" cy="40" r="11"></circle>
              <circle class="text-green-400 fill-current" cx="105" cy="40" r="11"></circle>
            </g>
          </svg>
        </div>
      </div>
    </div>

    <div class="bg-yellow-400">
      <div class="px-4 pt-16 mx-auto sm:max-w-xl md:max-w-full lg:max-w-screen-xl md:px-24 lg:px-8 lg:py-20">
        <div class="grid grid-cols-2 gap-x-24">
          <div class="content">
            <h3 class="mb-5 font-sans text-xl font-bold tracking-tight text-gray-900 sm:text-l sm:leading-none">
              Description</h3>
            <slot />
            {data.type === 'application' ? (
              <div class="flex flex-wrap gap-3 my-5">
                {data.url && (
                  <a class="px-4 py-2 inline-block rounded bg-gray-800 text-white italic hover:bg-primary"
                     href={data.url} target="_blank" title={`View ${data.title} on GitHub`}
                     rel="external nofollow">
                    View application
                  </a>
                )}
                {data.docs && (
                  <a class="px-4 py-2 inline-block rounded bg-gray-800 text-white italic hover:bg-primary"
                     href={data.docs} target="_blank" title={`View ${data.title} documentation`}
                     rel="external nofollow">
                    View docs
                  </a>
                )}
                {data.issues && (
                  <a class="px-4 py-2 inline-block rounded bg-gray-800 text-white italic hover:bg-primary"
                     href={data.issues} target="_blank" title={`View ${data.title} issues`}
                     rel="external nofollow">
                    View issues
                  </a>
                )}
              </div>
            ) : (
              !data.finished && data.url && (
                <a class="px-4 py-2 my-5 inline-block rounded bg-gray-800 text-white italic hover:bg-primary"
                   href={data.url} target="_blank" title={`Launch ${data.title}`}
                   rel={data.seo ? undefined : 'external nofollow'}>
                  View site
                </a>
              )
            )}
          </div>
          <div class="w-full grid grid-cols-2 gap-8">
            {data.client && (
              <div>
                <h4 class="mb-5 font-sans text-xl font-bold tracking-tight text-gray-900 sm:text-l sm:leading-none">Client</h4>
                {data.client}
              </div>
            )}
            {data.type === 'website' && (
                <div>
                  <h4 class="mb-5 font-sans text-xl font-bold tracking-tight text-gray-900 sm:text-l sm:leading-none">Year</h4>
                  {startStr} - {endStr}
                </div>
                <div>
                  <h4 class="mb-5 font-sans text-xl font-bold tracking-tight text-gray-900 sm:text-l sm:leading-none">Site Status</h4>
                  {data.status}
                </div>
            )}
            {data.supported_versions && data.supported_versions.length > 0 && (
              <div class="col-span-2">
                <h4 class="mb-5 font-sans text-xl font-bold tracking-tight text-gray-900 sm:text-l sm:leading-none">Works with</h4>
                <div class="flex flex-wrap gap-2">
                  {data.supported_versions.map((v) => (
                    <span class="px-2 py-1 text-sm bg-gray-800 text-white rounded">{v}</span>
                  ))}
                </div>
              </div>
            )}
            {data.type === 'application' && data.github_user && data.github_repo && (
              <GitHubStats github_user={data.github_user} github_repo={data.github_repo} />
            )}
          </div>
        </div>
      </div>
    </div>

    {(data.technologies?.length || data.infrastructure?.length) && (
      <div>
        <div class="px-4 pt-16 mx-auto sm:max-w-xl md:max-w-full lg:max-w-7xl md:px-24 lg:px-8 lg:py-20">
          <div class="grid grid-cols-6 gap-2">
            {data.technologies?.length ? (
              <div class="col-span-2">
                <h3 class="mb-5 font-sans text-xl font-bold tracking-tight text-gray-900 sm:text-l sm:leading-none">Technology stack</h3>
                <div class="grid grid-cols-2 gap-4">
                  {data.technologies.map((tech) => <div>{tech}</div>)}
                </div>
              </div>
            ) : null}
            {data.infrastructure?.length ? (
              <div class="col-span-4">
                <h4 class="mb-5 font-sans text-xl font-bold tracking-tight text-gray-900 sm:text-l sm:leading-none">Infrastructure</h4>
                <div class="grid grid-cols-4 gap-4">
                  {data.infrastructure.map((infra) => <div>{infra}</div>)}
                </div>
              </div>
            ) : null}
          </div>
        </div>
        {data.summary?.length && (
            <hr />
            <div class="px-4 pt-16 mx-auto sm:max-w-xl md:max-w-full lg:max-w-screen-xl md:px-24 lg:px-8 lg:py-20 content">
              <h3 class="mb-5 font-sans text-xl font-bold tracking-tight text-gray-900 sm:text-l sm:leading-none">Summary</h3>
              <ul class="list-disc list-inside">
                {data.summary.map((s) => <li>{s}</li>)}
              </ul>
            </div>
        )}
      </div>
    )}

    <PortfolioSegment block_title="More Work" excludeId={data.id} />
  </div>

  <Up slot="up" />
  <Footer slot="footer" />
</BaseLayout>
