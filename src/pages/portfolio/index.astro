---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Up from '../../components/Up.astro';

const allPortfolio = await getCollection('portfolio');
const sorted = allPortfolio.sort((a, b) => b.data.launched.getTime() - a.data.launched.getTime());

const websites     = sorted.filter(s => s.data.type === 'website');
const applications = sorted.filter(s => s.data.type === 'application');
const modules      = sorted.filter(s => s.data.type === 'module');

const portfolioImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/images/portfolio/*.{png,jpg,jpeg,gif,webp,avif}', { eager: true });
---
<BaseLayout
  meta_title="Portfolio of websites and plugins / modules"
  meta_description="Here is an example of works I've completed either individually or as part of a team."
>
  <Header slot="header" currentPath="/portfolio/" />
  <div slot="dropdown"></div>

  <div class="px-4 py-16 mx-auto sm:max-w-xl md:max-w-full lg:max-w-7xl md:px-24 lg:px-8 lg:py-20">
    <div class="max-w-screen-sm sm:text-center sm:mx-auto">
      <h1 class="mb-4 font-sans text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl sm:leading-none">
        Website Site and Project Portfolio
      </h1>
      <p class="text-base text-gray-700 md:text-lg sm:px-4">
        Sites I've either built or been responsible for the updates or maintenance of.
      </p>
      <hr class="w-full my-8 border-gray-300" />
    </div>

    {websites.length > 0 && (
      <>
        <h2 class="mb-6 font-sans text-2xl font-bold tracking-tight text-gray-900">Websites</h2>
        <div class="grid gap-6 row-gap-5 mb-8 lg:grid-cols-3 sm:row-gap-6 sm:grid-cols-2 gap-y-6">
          {websites.map((site) => {
            const imgSrc = portfolioImages[`../../assets/images/portfolio/${site.data.image_main}`]?.default;
            return (
              <a href={`/portfolio/${site.id}/`} aria-label="View Item">
                <div class="relative overflow-hidden transition duration-200 transform rounded shadow-lg hover:-translate-y-2 hover:shadow-2xl">
                  <div class={`flex items-center justify-center h-56 md:h-44 xl:h-56 ${site.data.type === 'application' ? 'bg-primary' : 'bg-white'}`}>
                    {imgSrc && (
                      <Image
                        src={imgSrc}
                        width={390}
                        alt={site.data.title}
                        title={site.data.title}
                        class="object-contain w-full h-full"
                      />
                    )}
                  </div>
                  <div class="absolute inset-0 px-6 py-4 transition-opacity duration-200 bg-black bg-opacity-75 opacity-0 hover:opacity-100">
                    <p class="mb-4 text-lg font-bold text-gray-100">{site.data.title}</p>
                    <p class="text-sm tracking-wide text-gray-300">{site.data.intro}</p>
                    {site.data.technologies?.length ? (
                      <div class="flex flex-wrap justify-starts items-center mt-4">
                        {site.data.technologies.map((tech) => (
                          <div class="text-xs mr-2 py-1.5 px-4 text-gray-600 bg-yellow-400 rounded-2xl mb-1.5">#{tech}</div>
                        ))}
                      </div>
                    ) : null}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </>
    )}

    {applications.length > 0 && (
      <>
        <hr class="w-full my-8 border-gray-300" />
        <h2 class="mb-6 font-sans text-2xl font-bold tracking-tight text-gray-900">Applications</h2>
        <div class="grid gap-6 row-gap-5 mb-8 lg:grid-cols-3 sm:row-gap-6 sm:grid-cols-2 gap-y-6">
          {applications.map((site) => {
            const imgSrc = portfolioImages[`../../assets/images/portfolio/${site.data.image_main}`]?.default;
            return (
              <a href={`/portfolio/${site.id}/`} aria-label="View Item">
                <div class="relative overflow-hidden transition duration-200 transform rounded shadow-lg hover:-translate-y-2 hover:shadow-2xl">
                  <div class={`flex items-center justify-center h-56 md:h-44 xl:h-56 ${site.data.type === 'application' ? 'bg-primary' : 'bg-white'}`}>
                    {imgSrc && (
                      <Image
                        src={imgSrc}
                        width={390}
                        alt={site.data.title}
                        title={site.data.title}
                        class="object-contain w-full h-full"
                      />
                    )}
                  </div>
                  <div class="absolute inset-0 px-6 py-4 transition-opacity duration-200 bg-black bg-opacity-75 opacity-0 hover:opacity-100">
                    <p class="mb-4 text-lg font-bold text-gray-100">{site.data.title}</p>
                    <p class="text-sm tracking-wide text-gray-300">{site.data.intro}</p>
                    {site.data.technologies?.length ? (
                      <div class="flex flex-wrap justify-starts items-center mt-4">
                        {site.data.technologies.map((tech) => (
                          <div class="text-xs mr-2 py-1.5 px-4 text-gray-600 bg-yellow-400 rounded-2xl mb-1.5">#{tech}</div>
                        ))}
                      </div>
                    ) : null}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </>
    )}

    {modules.length > 0 && (
      <>
        <hr class="w-full my-8 border-gray-300" />
        <h2 class="mb-6 font-sans text-2xl font-bold tracking-tight text-gray-900">Modules</h2>
        <div class="grid gap-6 row-gap-5 mb-8 lg:grid-cols-3 sm:row-gap-6 sm:grid-cols-2 gap-y-6">
          {modules.map((site) => {
            const imgSrc = portfolioImages[`../../assets/images/portfolio/${site.data.image_main}`]?.default;
            return (
              <a href={`/portfolio/${site.id}/`} aria-label="View Item">
                <div class="relative overflow-hidden transition duration-200 transform rounded shadow-lg hover:-translate-y-2 hover:shadow-2xl">
                  <div class={`flex items-center justify-center h-56 md:h-44 xl:h-56 ${site.data.type === 'application' ? 'bg-primary' : 'bg-white'}`}>
                    {imgSrc && (
                      <Image
                        src={imgSrc}
                        width={390}
                        alt={site.data.title}
                        title={site.data.title}
                        class="object-contain w-full h-full"
                      />
                    )}
                  </div>
                  <div class="absolute inset-0 px-6 py-4 transition-opacity duration-200 bg-black bg-opacity-75 opacity-0 hover:opacity-100">
                    <p class="mb-4 text-lg font-bold text-gray-100">{site.data.title}</p>
                    <p class="text-sm tracking-wide text-gray-300">{site.data.intro}</p>
                    {site.data.technologies?.length ? (
                      <div class="flex flex-wrap justify-starts items-center mt-4">
                        {site.data.technologies.map((tech) => (
                          <div class="text-xs mr-2 py-1.5 px-4 text-gray-600 bg-yellow-400 rounded-2xl mb-1.5">#{tech}</div>
                        ))}
                      </div>
                    ) : null}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </>
    )}
  </div>

  <Up slot="up" />
  <Footer slot="footer" />
</BaseLayout>
