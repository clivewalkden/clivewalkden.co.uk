{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "string"
        }
      ]
    },
    "title": {
      "type": "string"
    },
    "client": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "type": "string"
    },
    "url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "launched": {
      "type": "string",
      "format": "date-time"
    },
    "finished": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "technologies": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "infrastructure": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "image_main": {
      "type": "string"
    },
    "image_small": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "intro": {
      "type": "string"
    },
    "summary": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "meta_title": {
      "type": "string"
    },
    "meta_description": {
      "type": "string"
    },
    "seo": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "status",
    "launched",
    "featured",
    "technologies",
    "infrastructure",
    "image_main",
    "intro",
    "meta_title",
    "meta_description",
    "seo"
  ],
  "additionalProperties": false
}